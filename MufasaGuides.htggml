// ══════════════════════════════════════════
//  RENDER
// ══════════════════════════════════════════
function renderGuides() {
  const list = document.getElementById('guideList');
  list.innerHTML = GUIDES_DATA.map((g, gi) => {
    const sections = g.sections[currentGoal];
    const sHTML = sections.map(s => `
      <div class="gsub">
        <div class="gsub-hd">${s.title}</div>
        <ul>${s.pts.map(p => `<li>${p}</li>`).join('')}</ul>
      </div>`).join('');

    return `
      <div class="gitem fade-in" id="gitem-${g.id}" style="animation-delay:${gi * 0.07}s">
        <div class="ghd" onclick="toggleGuide('${g.id}')">
          <div class="ghd-ic">${g.icon}</div>
          <div class="ghd-info">
            <div class="ghd-t">${g.title}</div>
            <div class="ghd-s">${g.sub}</div>
          </div>
          <div class="garr">›</div>
        </div>
        <div class="gbody">
          <div class="gcont">
            <div class="gcont-divider"></div>
            <div class="goal-badge">📌 ${GOAL_LABELS[currentGoal]}</div>
            <div class="ghighlight">${GOAL_HIGHLIGHTS[g.id][currentGoal]}</div>
            ${sHTML}
          </div>
        </div>
      </div>`;
  }).join('');
}

function toggleGuide(id) {
  const el = document.getElementById('gitem-' + id);
  const wasOpen = el.classList.contains('open');
  // close all first
  document.querySelectorAll('.gitem').forEach(i => i.classList.remove('open'));
  // if it was closed, open it
  if (!wasOpen) el.classList.add('open');
}

// ══════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════
renderTip();
renderGuides();
</script>
</body>
</html>
