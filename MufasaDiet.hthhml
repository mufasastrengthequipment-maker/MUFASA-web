  },
  {id:'maint',icon:'⚖️',name:'MAINTENANCE',goal:'Stay Lean',cal:'2,400 kcal',macros:{p:'160g',c:'270g',f:'70g'},
    tip:'Consistency wins. Maintenance is not boring — it\'s the foundation of long-term health. Hit protein daily and train hard.',
    meals:[
      {time:'7:00 AM — Breakfast 🌅',rows:[
        {food:'Eggs (boiled)',qty:'3 eggs',cal:210,p:18,c:0,f:15},
        {food:'Brown bread',qty:'2 slices',cal:160,p:6,c:30,f:2},
        {food:'Avocado',qty:'½ medium',cal:115,p:1,c:6,f:10},
        {food:'Tea (no sugar)',qty:'1 cup',cal:15,p:0,c:2,f:0},
      ]},
      {time:'10:30 AM — Snack 🍌',rows:[
        {food:'Banana',qty:'1 medium',cal:105,p:1,c:27,f:0},
        {food:'Boiled egg',qty:'1 egg',cal:70,p:6,c:0,f:5},
      ]},
      {time:'1:00 PM — Lunch 🍽️',rows:[
        {food:'Ugali or Rice',qty:'200g cooked',cal:290,p:5,c:65,f:1},
        {food:'Chicken or fish',qty:'150g',cal:200,p:30,c:0,f:8},
        {food:'Sukuma / spinach',qty:'1 cup cooked',cal:40,p:3,c:5,f:1},
        {food:'Tomato salad',qty:'1 large tomato',cal:25,p:1,c:5,f:0},
      ]},
      {time:'4:00 PM — Pre-Workout 💪',rows:[
        {food:'Sweet potato',qty:'130g',cal:112,p:2,c:26,f:0},
        {food:'Peanut butter',qty:'1 tbsp (16g)',cal:95,p:4,c:3,f:8},
