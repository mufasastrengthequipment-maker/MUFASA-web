<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MUFASA — Diet Plans</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --g:#D4942A;--gl:#F0B84A;--gd:#A8741F;
  --gdim:rgba(212,148,42,.2);--gfaint:rgba(212,148,42,.06);
  --bg:#050403;--s1:#0C0A08;--s2:#121008;
  --card:#18150F;--card2:#1F1B12;
  --b1:rgba(212,148,42,.13);--b2:rgba(212,148,42,.32);
  --w:#F4EFE4;--grey:#A09890;--dim:#7A7570;
  --r:6px;--r2:12px;--r3:20px;
  --prot:#7ec8a0;--carb:#F0B84A;--fat:#e07850;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--w);min-height:100vh;overflow-x:hidden;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:var(--s1);}
::-webkit-scrollbar-thumb{background:var(--b2);border-radius:2px;}

/* ── WRAPPER ── */
.diet-wrap{padding:28px 5vw 80px;max-width:900px;margin:0 auto;}

/* ── HEADER ── */
.diet-header{margin-bottom:26px;}
.stag{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--g);margin-bottom:6px;}
.sh{font-family:'Anton',sans-serif;font-size:clamp(1.8rem,5vw,2.8rem);line-height:1;color:var(--w);margin-bottom:6px;}
.ssub{font-size:.88rem;color:var(--grey);line-height:1.6;}

/* ── TIP BANNER ── */
.tip-banner{
  background:linear-gradient(135deg,var(--card),var(--card2));
  border:1px solid var(--b2);border-left:3px solid var(--g);
  border-radius:var(--r2);padding:14px 18px;margin-bottom:28px;
  display:flex;align-items:flex-start;gap:12px;
  animation:tipIn .5s ease both;
}
@keyframes tipIn{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:none;}}
.tip-icon{font-size:1.3rem;flex-shrink:0;margin-top:1px;}
.tip-label{font-family:'Barlow Condensed',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--g);margin-bottom:3px;}
.tip-text{font-size:.86rem;color:var(--w);line-height:1.55;}
.tip-refresh{background:none;border:none;color:var(--dim);font-size:.75rem;cursor:pointer;margin-top:5px;font-family:'Barlow Condensed',sans-serif;letter-spacing:.1em;text-transform:uppercase;transition:color .2s;padding:0;}
.tip-refresh:hover{color:var(--g);}

/* ── MACROS KEY ── */
.macro-key{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap;}
.mkey-item{display:flex;align-items:center;gap:6px;font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--grey);}
.mkey-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}

/* ── GOAL SELECTOR GRID ── */
.goal-selector{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:10px;margin-bottom:28px;}

.gcard{
  background:var(--card);border:1px solid var(--b1);
  border-radius:var(--r2);padding:18px 16px;
  cursor:pointer;transition:all .22s;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;gap:8px;
}
.gcard:hover{border-color:var(--b2);transform:translateY(-3px);box-shadow:0 10px 28px rgba(212,148,42,.09);}
.gcard.sel{border-color:var(--g);background:var(--gdim);box-shadow:0 0 0 1px var(--g);}
.gc-ic{font-size:2rem;line-height:1;}
.gc-nm{font-family:'Anton',sans-serif;font-size:.95rem;letter-spacing:.04em;color:var(--w);}
.gc-ds{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;color:var(--grey);letter-spacing:.05em;}
.gc-cal{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;color:var(--g);margin-top:2px;}
.gcard.sel .gc-nm{color:var(--gl);}

/* ── PLAN DETAIL ── */
.pdetail{
  background:var(--card);border:1px solid var(--b1);
  border-radius:var(--r3);overflow:hidden;
  margin-bottom:20px;
  animation:pdin .35s ease both;
}
@keyframes pdin{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

.phd{
  display:flex;align-items:flex-start;justify-content:space-between;
  gap:14px;
  padding:20px 22px;
  background:var(--s1);border-bottom:1px solid var(--b1);
  flex-wrap:wrap;
}
.pt{font-family:'Anton',sans-serif;font-size:1.5rem;color:var(--w);line-height:1;margin-bottom:8px;}
.pmetas{display:flex;gap:6px;flex-wrap:wrap;}
.pmeta{
  font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;
  letter-spacing:.1em;color:var(--grey);
  background:var(--s2);border:1px solid var(--b1);
  border-radius:4px;padding:3px 9px;
}
.prt-btn{
  background:linear-gradient(135deg,var(--gd),var(--gl));border:none;
  color:var(--bg);padding:8px 16px;border-radius:var(--r);
  font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;cursor:pointer;
  transition:opacity .2s;white-space:nowrap;flex-shrink:0;
}
.prt-btn:hover{opacity:.85;}

.pbody{padding:22px;}

/* ── MACRO BAR ── */
.macro-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:10px;margin-bottom:24px;
}
.macro-item{
  background:var(--s1);border:1px solid var(--b1);
  border-radius:var(--r2);padding:14px 12px;text-align:center;
}
.macro-v{font-family:'Anton',sans-serif;font-size:1.1rem;line-height:1;margin-bottom:4px;}
.macro-l{font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--grey);}
.macro-item.prot .macro-v{color:var(--prot);}
.macro-item.carb .macro-v{color:var(--carb);}
.macro-item.fat  .macro-v{color:var(--fat);}

/* ── VISUAL MACRO BARS ── */
.macro-visual{
  background:var(--s1);border:1px solid var(--b1);
  border-radius:var(--r2);padding:14px 18px;margin-bottom:24px;
}
.macro-visual-label{font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--grey);margin-bottom:10px;}
.mbar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.mbar-row:last-child{margin-bottom:0;}
.mbar-name{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;width:58px;text-transform:uppercase;letter-spacing:.04em;flex-shrink:0;}
.mbar-track{flex:1;height:7px;background:var(--b1);border-radius:4px;overflow:hidden;}
.mbar-fill{height:100%;border-radius:4px;transition:width 1s cubic-bezier(.4,0,.2,1);}
.mbar-val{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;width:52px;text-align:right;flex-shrink:0;}

/* ── MEAL SECTIONS ── */
.meal-sec{margin-bottom:24px;}
.meal-sec:last-child{margin-bottom:0;}
.meal-time{
  font-family:'Barlow Condensed',sans-serif;font-size:.85rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;color:var(--g);
  margin-bottom:10px;
  display:flex;align-items:center;gap:8px;
}
.meal-time::before{content:'';display:inline-block;width:20px;height:2px;background:var(--g);}

.meal-cal-row{
  display:flex;gap:8px;flex-wrap:wrap;
  margin-bottom:8px;
}
.meal-cal-tag{
  font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  background:var(--s2);border:1px solid var(--b1);
  border-radius:4px;padding:3px 8px;color:var(--grey);
}
.meal-cal-tag.total{color:var(--gl);border-color:var(--b2);}

/* table */
.mtable{width:100%;border-collapse:collapse;}
.mtable thead tr{background:var(--s2);}
.mtable th{
  font-family:'Barlow Condensed',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.15em;text-transform:uppercase;color:var(--grey);
  padding:7px 10px;text-align:left;border-bottom:1px solid var(--b1);
  white-space:nowrap;
}
.mtable td{padding:9px 10px;border-bottom:1px solid rgba(212,148,42,.05);font-size:.83rem;vertical-align:middle;}
.mtable tbody tr:hover{background:var(--gfaint);}
.mtable td.food{font-weight:500;color:var(--w);}
.mtable td.qty{color:var(--grey);font-size:.78rem;}
.mtable td.cal{color:var(--gl);font-weight:600;}
.mtable td.prot{color:var(--prot);font-weight:600;}
.mtable td.carb{color:var(--carb);}
.mtable td.fat {color:var(--fat);}

/* mobile overflow */
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}

/* ── TOTAL ROW ── */
.total-row td{
  border-top:1px solid var(--b2)!important;
  border-bottom:none!important;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  background:var(--s2)!important;
}

/* ── MEAL SUMMARY CARD (mobile toggle) ── */
.meal-card{
  background:var(--s2);border:1px solid var(--b1);
  border-radius:var(--r2);overflow:hidden;margin-bottom:10px;
  transition:border-color .2s;
}
.meal-card.open{border-color:var(--b2);}
.meal-hd{
  display:flex;align-items:center;gap:12px;
  padding:12px 14px;cursor:pointer;
  transition:background .2s;user-select:none;
}
.meal-hd:hover{background:var(--gfaint);}
.meal-hd-time{
  font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;color:var(--g);flex:1;
}
.meal-hd-cal{
  font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;
  color:var(--grey);flex-shrink:0;
}
.meal-hd-arr{
  color:var(--dim);font-size:16px;flex-shrink:0;
  transition:transform .25s;
}
.meal-card.open .meal-hd-arr{transform:rotate(180deg);}
.meal-body{
  max-height:0;overflow:hidden;
  transition:max-height .35s cubic-bezier(.77,0,.18,1);
}
.meal-card.open .meal-body{max-height:600px;}
.meal-inner{padding:0 14px 14px;}

/* ── DAILY SUMMARY ── */
.day-summary{
  background:linear-gradient(135deg,var(--card),var(--card2));
  border:1px solid var(--b2);border-radius:var(--r2);
  padding:16px 20px;margin-bottom:24px;
  display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:12px;
}
.ds-item{text-align:center;}
.ds-val{font-family:'Anton',sans-serif;font-size:1.4rem;color:var(--gl);line-height:1;}
.ds-lbl{font-family:'Barlow Condensed',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--grey);margin-top:3px;}

/* ── SHOPPING LIST ── */
.shopping-wrap{margin-top:28px;}
.shopping-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;flex-wrap:wrap;gap:10px;
}
.shopping-title{font-family:'Anton',sans-serif;font-size:1.1rem;color:var(--w);}
.shopping-btn{
  background:none;border:1px solid var(--b2);color:var(--gl);
  font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  padding:7px 14px;border-radius:var(--r);cursor:pointer;
  transition:all .2s;
}
.shopping-btn:hover{background:var(--gfaint);border-color:var(--g);}
.shopping-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;}
.s-item{
  background:var(--s2);border:1px solid var(--b1);
  border-radius:var(--r);padding:9px 12px;
  font-size:.83rem;display:flex;align-items:center;gap:8px;
  cursor:pointer;transition:all .18s;
  user-select:none;
}
.s-item:hover{border-color:var(--b2);background:var(--gfaint);}
.s-item.checked{opacity:.45;text-decoration:line-through;color:var(--dim);}
.s-item-dot{
  width:16px;height:16px;border-radius:50%;
  border:1.5px solid var(--b2);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;transition:all .2s;
}
.s-item.checked .s-item-dot{background:var(--g);border-color:var(--g);color:var(--bg);}

/* ── WA SHARE BUTTON ── */
.wa-btn{
  display:inline-flex;align-items:center;gap:8px;
  background:linear-gradient(135deg,#1a7a3a,#22a050);
  color:#fff;font-family:'Barlow Condensed',sans-serif;
  font-size:.82rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  padding:10px 20px;border:none;border-radius:var(--r);cursor:pointer;
  transition:opacity .2s;text-decoration:none;
}
.wa-btn:hover{opacity:.85;}

/* ── EMPTY STATE ── */
.empty{
  padding:48px 20px;text-align:center;
  font-family:'Barlow Condensed',sans-serif;font-size:.9rem;color:var(--grey);line-height:1.8;
}
.empty strong{color:var(--g);display:block;font-size:1.3rem;margin-bottom:8px;font-family:'Anton',sans-serif;}

/* ── VIEW TOGGLE ── */
.view-toggle{
  display:flex;gap:4px;background:var(--s1);
  border:1px solid var(--b1);border-radius:var(--r);
  padding:3px;width:fit-content;margin-bottom:18px;
}
.vt-btn{
  font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  background:none;border:none;color:var(--grey);
  padding:5px 13px;border-radius:4px;cursor:pointer;transition:all .2s;
}
.vt-btn.on{background:var(--g);color:var(--bg);}

/* ── PRINT ── */
@media print{
  body{background:#fff!important;color:#111!important;}
  .no-print{display:none!important;}
  .mtable th{background:#1a1a1a!important;color:#fff!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .mtable td{border-bottom:1px solid #eee!important;}
  .phd,.macro-visual,.macro-row{background:#f9f6ef!important;}
}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  .goal-selector{grid-template-columns:repeat(2,1fr);}
  .macro-row{grid-template-columns:repeat(3,1fr);}
  .day-summary{grid-template-columns:repeat(2,1fr);}
  .phd{padding:16px;}
  .pt{font-size:1.2rem;}
  .shopping-grid{grid-template-columns:1fr 1fr;}
}
@media(max-width:420px){
  .goal-selector{grid-template-columns:1fr 1fr;}
  .macro-row{grid-template-columns:1fr 1fr 1fr;}
}
</style>
</head>
<body>

<div class="diet-wrap">

  <!-- HEADER -->
  <div class="diet-header">
    <div class="stag">Eat Right · Kenya</div>
    <h1 class="sh">DIET PLANS</h1>
    <p class="ssub">Nutrition is 70% of the game. Kenyan foods. Real quantities. Real results.</p>
  </div>

  <!-- TIP BANNER -->
  <div class="tip-banner" id="tipBanner">
    <div class="tip-icon" id="tipIcon">🥑</div>
    <div>
      <div class="tip-label">Nutrition Tip of the Week</div>
      <div class="tip-text" id="tipText">Loading tip…</div>
      <button class="tip-refresh" onclick="nextTip()">↻ NEXT TIP</button>
    </div>
  </div>

  <!-- MACRO COLOR KEY -->
  <div class="macro-key">
    <div class="mkey-item"><div class="mkey-dot" style="background:var(--prot)"></div>Protein</div>
    <div class="mkey-item"><div class="mkey-dot" style="background:var(--carb)"></div>Carbs</div>
    <div class="mkey-item"><div class="mkey-dot" style="background:var(--fat)"></div>Fat</div>
  </div>

  <!-- GOAL CARDS -->
  <div class="goal-selector" id="dGoalGrid"></div>

  <!-- PLAN DETAIL (rendered here) -->
  <div id="dPlanWrap"></div>

</div>

<!-- PRINT MODAL -->
<div id="printModal" style="display:none;position:fixed;inset:0;z-index:3000;background:rgba(5,4,3,.97);overflow-y:auto;padding:40px 20px;">
  <div style="background:#fff;color:#111;max-width:750px;width:100%;border-radius:8px;padding:40px;margin:0 auto;position:relative;">
    <button onclick="closePrint()" style="position:absolute;top:14px;right:14px;background:none;border:1px solid #ccc;border-radius:4px;padding:6px 12px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.78rem;font-weight:700;color:#333">✕ CLOSE</button>
    <button onclick="window.print()" style="position:absolute;top:14px;right:90px;background:#D4942A;color:#fff;border:none;border-radius:4px;padding:6px 14px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.78rem;font-weight:700;">🖨️ PRINT</button>
    <div id="printContent"></div>
    <p style="margin-top:20px;font-size:.72rem;color:#999">MUFASA STRENGTH EQUIPMENT · WhatsApp: 0115 228 712 · mufasastrength.com</p>
  </div>
</div>

<script>
// ══════════════════════════════════════
//   TIPS
// ══════════════════════════════════════
const TIPS=[
  {icon:'🥑',text:'Prioritise protein at every meal. Aim for at least 25–30g per sitting — eggs, fish, chicken, beef, beans, or yogurt. Protein keeps you full and preserves muscle.'},
  {icon:'🍠',text:'Sweet potato is Kenya\'s best pre-workout carb. Eat 100–150g about 60–90 minutes before training for steady energy without the crash.'},
  {icon:'💧',text:'Drink at least 2 litres of water daily. Performance drops as soon as you are 2% dehydrated. Start every morning with a full glass before anything else.'},
  {icon:'🧪',text:'You cannot out-train a bad diet. If fat loss is your goal, your calorie intake matters more than any workout plan. Track your food for just one week to see where you stand.'},
  {icon:'🥚',text:'Eggs are the most complete protein available in Kenya at a low cost. 3 whole eggs give you 18g protein and critical vitamins. Do not throw away the yolk.'},
  {icon:'🌿',text:'Add sukuma wiki or spinach to at least two meals daily. These are packed with iron, calcium, and vitamins for a fraction of the cost of imported vegetables.'},
  {icon:'⏰',text:'Meal timing matters less than meal quality. Eat 3–5 structured meals and focus on hitting your protein target. Skipping meals often leads to overeating later.'},
  {icon:'🫘',text:'Beans and lentils are underrated. Cheap, high in protein, high in fibre, and extremely filling. A cup of cooked lentils delivers 18g protein for under KSH 30.'},
];
let tipIdx=Math.floor(Math.random()*TIPS.length);
function renderTip(){
  const t=TIPS[tipIdx];
  document.getElementById('tipIcon').textContent=t.icon;
  document.getElementById('tipText').textContent=t.text;
}
function nextTip(){tipIdx=(tipIdx+1)%TIPS.length;renderTip();}

// ══════════════════════════════════════
//   DIET DATA — Kenyan foods
// ══════════════════════════════════════
const DIET_PLANS=[
  {id:'lean',icon:'🥗',name:'LEAN CUT',goal:'Weight Loss',cal:'1,850 kcal',macros:{p:'155g',c:'185g',f:'52g'},
    tip:'Eat slowly, drink water before meals, and never skip breakfast. Ugali + tilapia is one of Kenya\'s best fat-loss meals.',
    meals:[
      {time:'7:00 AM — Breakfast 🌅',rows:[
        {food:'Oats (rolled)',qty:'80g / 1 cup',cal:300,p:10,c:54,f:6},
        {food:'Boiled Eggs',qty:'3 whole eggs',cal:210,p:18,c:0,f:15},
        {food:'Banana',qty:'1 medium (120g)',cal:105,p:1,c:27,f:0},
        {food:'Black coffee / green tea',qty:'1 cup',cal:5,p:0,c:0,f:0},
      ]},
      {time:'10:30 AM — Mid-Morning 🍎',rows:[
        {food:'Plain yogurt',qty:'150g / ½ cup',cal:130,p:15,c:8,f:4},
        {food:'Apple',qty:'1 medium (180g)',cal:95,p:0,c:25,f:0},
      ]},
      {time:'1:00 PM — Lunch 🍽️',rows:[
        {food:'Ugali',qty:'200g / 1 cup cooked',cal:290,p:5,c:65,f:1},
        {food:'Tilapia / mackerel (grilled)',qty:'150g fillet',cal:200,p:30,c:0,f:8},
        {food:'Sukuma wiki',qty:'1 cup cooked',cal:40,p:3,c:5,f:1},
        {food:'Tomato & avocado salad',qty:'½ avo + 1 tomato',cal:110,p:1,c:6,f:8},
      ]},
      {time:'4:00 PM — Pre-Workout 💪',rows:[
        {food:'Sweet potato (boiled)',qty:'150g / 1 medium',cal:130,p:2,c:30,f:0},
        {food:'Boiled eggs',qty:'2 eggs',cal:140,p:12,c:0,f:10},
      ]},
      {time:'7:30 PM — Dinner 🌙',rows:[
        {food:'Brown rice',qty:'150g cooked / ¾ cup',cal:165,p:4,c:35,f:1},
        {food:'Chicken breast (grilled)',qty:'180g',cal:220,p:40,c:0,f:5},
        {food:'Mixed vegetables (stir-fried)',qty:'1 cup',cal:60,p:3,c:10,f:2},
      ]},
    ]
  },
  {id:'bulk',icon:'🍗',name:'MUSCLE FUEL',goal:'Muscle Gain',cal:'3,050 kcal',macros:{p:'200g',c:'340g',f:'80g'},
    tip:'Eat every 3 hours, prioritise whole foods over supplements, and never go to bed hungry during a bulk.',
    meals:[
      {time:'6:30 AM — Breakfast 🌅',rows:[
        {food:'Oats',qty:'120g / 1.5 cups',cal:450,p:15,c:80,f:9},
