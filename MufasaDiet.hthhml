      {time:'7:30 PM — Dinner 🌙',rows:[
        {food:'Brown rice',qty:'150g cooked',cal:165,p:4,c:35,f:1},
        {food:'Beef / chicken / fish',qty:'160g',cal:240,p:35,c:0,f:10},
        {food:'Mixed veg stir-fry',qty:'1 cup',cal:60,p:3,c:10,f:2},
      ]},
    ]
  },
  {id:'plant',icon:'🌿',name:'PLANT-BASED',goal:'Vegan Strength',cal:'2,100 kcal',macros:{p:'130g',c:'280g',f:'60g'},
    tip:'Combine different plant proteins (beans + rice, lentils + bread) at every meal to ensure complete amino acid profiles.',
    meals:[
      {time:'7:00 AM — Breakfast 🌅',rows:[
        {food:'Oats with soy milk',qty:'80g oats + 200ml soy milk',cal:340,p:14,c:52,f:9},
        {food:'Chia seeds',qty:'2 tbsp (28g)',cal:140,p:5,c:12,f:9},
        {food:'Banana + berries',qty:'1 banana + ½ cup berries',cal:130,p:1,c:33,f:0},
      ]},
      {time:'10:30 AM — Snack 🥜',rows:[
        {food:'Groundnuts (plain)',qty:'40g / small handful',cal:230,p:10,c:6,f:20},
        {food:'Orange',qty:'1 medium',cal:70,p:1,c:17,f:0},
      ]},
      {time:'1:00 PM — Lunch 🍽️',rows:[
        {food:'Brown rice',qty:'200g cooked / 1 cup',cal:220,p:5,c:46,f:2},
        {food:'Lentil stew',qty:'200g / 1 cup',cal:230,p:18,c:38,f:1},
        {food:'Spinach / kale (stir-fried)',qty:'1 cup',cal:35,p:3,c:4,f:1},
        {food:'Avocado',qty:'½ medium',cal:115,p:1,c:6,f:10},
      ]},
      {time:'4:00 PM — Pre-Workout 💪',rows:[
        {food:'Sweet potato',qty:'150g',cal:130,p:2,c:30,f:0},
        {food:'Peanut butter on bread',qty:'2 tbsp + 1 slice',cal:275,p:10,c:23,f:18},
      ]},
      {time:'7:30 PM — Dinner 🌙',rows:[
        {food:'Kidney beans + chickpeas',qty:'200g cooked mixed',cal:280,p:18,c:50,f:2},
        {food:'Coconut rice',qty:'150g cooked',cal:210,p:4,c:38,f:5},
        {food:'Kachumbari',qty:'1 cup (tomato/onion/coriander)',cal:35,p:1,c:7,f:0},
      ]},
    ]
  },
];

// ══════════════════════════════════════
//   STATE
// ══════════════════════════════════════
let selPlan=null;
let viewMode='cards'; // 'cards' or 'table'
let checkedItems=new Set();

// ══════════════════════════════════════
//   HELPERS
// ══════════════════════════════════════
function mealTotal(rows){
  return rows.reduce((a,r)=>({cal:a.cal+r.cal,p:a.p+r.p,c:a.c+r.c,f:a.f+r.f}),{cal:0,p:0,c:0,f:0});
}
function dayTotal(meals){
  return meals.reduce((a,m)=>{const t=mealTotal(m.rows);return{cal:a.cal+t.cal,p:a.p+t.p,c:a.c+t.c,f:a.f+t.f};},{cal:0,p:0,c:0,f:0});
}

// ══════════════════════════════════════
//   INIT GOAL GRID
// ══════════════════════════════════════
function initGoalGrid(){
  document.getElementById('dGoalGrid').innerHTML=DIET_PLANS.map(d=>{
    const tot=dayTotal(d.meals);
    return `<div class="gcard" id="dg-${d.id}" onclick="selDPlan('${d.id}')">
      <div class="gc-ic">${d.icon}</div>
      <div class="gc-nm">${d.name}</div>
      <div class="gc-ds">${d.goal}</div>
      <div class="gc-cal">🔥 ${d.cal}</div>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════
//   SELECT PLAN
// ══════════════════════════════════════
function selDPlan(id){
  selPlan=DIET_PLANS.find(d=>d.id===id);
  checkedItems=new Set();
  document.querySelectorAll('.gcard').forEach(c=>c.classList.remove('sel'));
  const gc=document.getElementById('dg-'+id);if(gc)gc.classList.add('sel');

  const tot=dayTotal(selPlan.meals);
  // Compute max macro for bar widths
  const maxMacro=Math.max(parseInt(selPlan.macros.p),parseInt(selPlan.macros.c),parseInt(selPlan.macros.f));

  const barWidth=(val,max)=>Math.round((val/max)*100);

  const mealsHTML=selPlan.meals.map((m,mi)=>{
    const mt=mealTotal(m.rows);
    const rowsHTML=m.rows.map(r=>`
      <tr>
        <td class="food">${r.food}</td>
        <td class="qty">${r.qty}</td>
        <td class="cal">${r.cal}</td>
        <td class="prot">${r.p}g</td>
        <td class="carb">${r.c}g</td>
        <td class="fat">${r.f}g</td>
      </tr>`).join('');
    const totalRow=`<tr class="total-row">
      <td colspan="2" style="color:var(--gl)">MEAL TOTAL</td>
      <td class="cal">${mt.cal}</td>
      <td class="prot">${mt.p}g</td>
      <td class="carb">${mt.c}g</td>
      <td class="fat">${mt.f}g</td>
    </tr>`;

    if(viewMode==='table'){
      return `<div class="meal-sec">
        <div class="meal-time">${m.time}</div>
        <div class="table-wrap">
          <table class="mtable">
            <thead><tr>
              <th>FOOD</th><th>QUANTITY</th><th>CAL</th>
              <th style="color:var(--prot)">PROTEIN</th>
              <th style="color:var(--carb)">CARBS</th>
              <th style="color:var(--fat)">FAT</th>
            </tr></thead>
            <tbody>${rowsHTML}${totalRow}</tbody>
          </table>
        </div>
      </div>`;
    } else {
      // Card / accordion mode
      const itemsHTML=m.rows.map(r=>`
        <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(212,148,42,.06);">
          <div>
            <div style="font-size:.86rem;font-weight:500;color:var(--w)">${r.food}</div>
            <div style="font-size:.75rem;color:var(--grey);margin-top:1px">${r.qty}</div>
          </div>
          <div style="text-align:right;flex-shrink:0;margin-left:12px">
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;color:var(--gl)">${r.cal} kcal</div>
            <div style="font-size:.7rem;margin-top:2px">
              <span style="color:var(--prot)">${r.p}g P</span>
              <span style="color:var(--dim)"> · </span>
              <span style="color:var(--carb)">${r.c}g C</span>
              <span style="color:var(--dim)"> · </span>
              <span style="color:var(--fat)">${r.f}g F</span>
            </div>
          </div>
        </div>`).join('');

      return `<div class="meal-card" id="meal-${mi}">
        <div class="meal-hd" onclick="toggleMeal(${mi})">
          <div class="meal-hd-time">${m.time}</div>
          <div class="meal-hd-cal">${mt.cal} kcal</div>
          <div class="meal-hd-arr">⌄</div>
        </div>
        <div class="meal-body">
          <div class="meal-inner">
            ${itemsHTML}
            <div style="display:flex;justify-content:space-between;align-items:center;padding-top:10px;margin-top:2px;border-top:1px solid var(--b2);">
              <span style="font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--grey)">Meal Total</span>
              <div style="display:flex;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;">
                <span style="color:var(--gl)">${mt.cal} kcal</span>
                <span style="color:var(--prot)">${mt.p}g P</span>
                <span style="color:var(--carb)">${mt.c}g C</span>
                <span style="color:var(--fat)">${mt.f}g F</span>
              </div>
            </div>
          </div>
        </div>
      </div>`;
    }
  }).join('');

  // Shopping list
  const allFoods=[...new Set(selPlan.meals.flatMap(m=>m.rows.map(r=>r.food)))];
  const shoppingHTML=allFoods.map((f,i)=>`
    <div class="s-item" id="si-${i}" onclick="toggleShop(${i},'${f.replace(/'/g,"\\'")}')">
      <div class="s-item-dot">✓</div>
      <span>${f}</span>
    </div>`).join('');

  document.getElementById('dPlanWrap').innerHTML=`
    <div class="pdetail">
      <!-- PLAN HEADER -->
      <div class="phd">
        <div>
          <div class="pt">${selPlan.icon} ${selPlan.name} PLAN</div>
          <div class="pmetas">
            <span class="pmeta">🎯 ${selPlan.goal}</span>
            <span class="pmeta">🔥 ${selPlan.cal}</span>
            <span class="pmeta">🥩 ${selPlan.macros.p} protein</span>
            <span class="pmeta">🍚 ${selPlan.macros.c} carbs</span>
            <span class="pmeta">🥑 ${selPlan.macros.f} fat</span>
          </div>
        </div>
        <button class="prt-btn no-print" onclick="doPrint()">🖨️ PRINT PLAN</button>
      </div>

      <div class="pbody">

        <!-- DAILY TOTALS -->
        <div class="day-summary">
          <div class="ds-item"><div class="ds-val">${tot.cal}</div><div class="ds-lbl">Total kcal</div></div>
          <div class="ds-item"><div class="ds-val" style="color:var(--prot)">${tot.p}g</div><div class="ds-lbl">Protein</div></div>
          <div class="ds-item"><div class="ds-val" style="color:var(--carb)">${tot.c}g</div><div class="ds-lbl">Carbs</div></div>
          <div class="ds-item"><div class="ds-val" style="color:var(--fat)">${tot.f}g</div><div class="ds-lbl">Fat</div></div>
        </div>

        <!-- MACRO VISUAL BARS -->
        <div class="macro-visual">
          <div class="macro-visual-label">Daily Macro Split</div>
          <div class="mbar-row">
            <div class="mbar-name" style="color:var(--prot)">Protein</div>
            <div class="mbar-track"><div class="mbar-fill" id="bar-p" style="background:var(--prot);width:0%"></div></div>
            <div class="mbar-val" style="color:var(--prot)">${selPlan.macros.p}</div>
          </div>
          <div class="mbar-row">
            <div class="mbar-name" style="color:var(--carb)">Carbs</div>
            <div class="mbar-track"><div class="mbar-fill" id="bar-c" style="background:var(--carb);width:0%"></div></div>
            <div class="mbar-val" style="color:var(--carb)">${selPlan.macros.c}</div>
          </div>
          <div class="mbar-row">
            <div class="mbar-name" style="color:var(--fat)">Fat</div>
            <div class="mbar-track"><div class="mbar-fill" id="bar-f" style="background:var(--fat);width:0%"></div></div>
            <div class="mbar-val" style="color:var(--fat)">${selPlan.macros.f}</div>
          </div>
        </div>

        <!-- PLAN TIP -->
        <div style="background:var(--s1);border:1px solid var(--b1);border-left:3px solid var(--g);border-radius:var(--r2);padding:12px 16px;margin-bottom:24px;font-size:.84rem;color:var(--grey);line-height:1.6;">
          <span style="color:var(--g);font-weight:700;font-family:'Barlow Condensed',sans-serif;font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;">PLAN TIP </span>
          ${selPlan.tip}
        </div>

        <!-- VIEW TOGGLE -->
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--grey);">Daily Meals</div>
          <div class="view-toggle">
            <button class="vt-btn ${viewMode==='cards'?'on':''}" onclick="setView('cards')">📋 Cards</button>
            <button class="vt-btn ${viewMode==='table'?'on':''}" onclick="setView('table')">📊 Table</button>
          </div>
        </div>

        <!-- MEALS -->
        <div id="mealsContainer">${mealsHTML}</div>

        <!-- SHOPPING LIST -->
        <div class="shopping-wrap">
          <div class="shopping-header">
            <div class="shopping-title">🛒 Shopping List</div>
            <button class="shopping-btn" onclick="clearChecks()">↺ Reset</button>
          </div>
          <div class="shopping-grid">${shoppingHTML}</div>
        </div>

        <!-- WA SHARE -->
        <div style="margin-top:24px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
          <a class="wa-btn" href="https://wa.me/254115228712?text=${encodeURIComponent('🥗 I want to follow the MUFASA ' + selPlan.name + ' plan! Can you send me more details?')}" target="_blank">💬 DISCUSS ON WHATSAPP</a>
          <button onclick="doPrint()" class="shopping-btn no-print">🖨️ PRINT PLAN</button>
        </div>

      </div>
    </div>`;

  // Animate macro bars after render
  setTimeout(()=>{
    const pVal=parseInt(selPlan.macros.p);
    const cVal=parseInt(selPlan.macros.c);
    const fVal=parseInt(selPlan.macros.f);
    const maxV=Math.max(pVal,cVal,fVal);
    const bp=document.getElementById('bar-p');
    const bc=document.getElementById('bar-c');
    const bf=document.getElementById('bar-f');
    if(bp)bp.style.width=Math.round(pVal/maxV*100)+'%';
    if(bc)bc.style.width=Math.round(cVal/maxV*100)+'%';
    if(bf)bf.style.width=Math.round(fVal/maxV*100)+'%';
  },80);

  // Auto-open first meal
  if(viewMode==='cards'){
    setTimeout(()=>{
      const first=document.getElementById('meal-0');
      if(first)first.classList.add('open');
    },100);
  }

  document.getElementById('dPlanWrap').scrollIntoView({behavior:'smooth',block:'start'});
}

function toggleMeal(i){
  const el=document.getElementById('meal-'+i);
  if(el)el.classList.toggle('open');
}

function setView(mode){
  viewMode=mode;
  if(selPlan)selDPlan(selPlan.id);
}

function toggleShop(i,food){
  const el=document.getElementById('si-'+i);
  if(!el)return;
  if(checkedItems.has(food)){checkedItems.delete(food);el.classList.remove('checked');}
  else{checkedItems.add(food);el.classList.add('checked');}
}

function clearChecks(){
  checkedItems.clear();
  document.querySelectorAll('.s-item').forEach(el=>el.classList.remove('checked'));
}

// ══════════════════════════════════════
//   PRINT
// ══════════════════════════════════════
function doPrint(){
  if(!selPlan)return;
  const tot=dayTotal(selPlan.meals);
  const html=`
    <h2 style="font-family:Arial,sans-serif;font-size:1.6rem;color:#1a1a1a;margin-bottom:4px">${selPlan.icon} ${selPlan.name} DIET PLAN</h2>
    <p style="font-size:.82rem;color:#555;margin-bottom:16px">Goal: ${selPlan.goal} · ${selPlan.cal} · Protein: ${selPlan.macros.p} | Carbs: ${selPlan.macros.c} | Fat: ${selPlan.macros.f}</p>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px">
      <div style="background:#f9f6ef;border:1px solid #ddd;border-radius:6px;padding:10px;text-align:center"><div style="font-size:1.2rem;font-weight:700;color:#D4942A">${tot.cal}</div><div style="font-size:.7rem;color:#666">Total kcal</div></div>
      <div style="background:#f9f6ef;border:1px solid #ddd;border-radius:6px;padding:10px;text-align:center"><div style="font-size:1.2rem;font-weight:700;color:#22a050">${tot.p}g</div><div style="font-size:.7rem;color:#666">Protein</div></div>
      <div style="background:#f9f6ef;border:1px solid #ddd;border-radius:6px;padding:10px;text-align:center"><div style="font-size:1.2rem;font-weight:700;color:#D4942A">${tot.c}g</div><div style="font-size:.7rem;color:#666">Carbs</div></div>
      <div style="background:#f9f6ef;border:1px solid #ddd;border-radius:6px;padding:10px;text-align:center"><div style="font-size:1.2rem;font-weight:700;color:#e07850">${tot.f}g</div><div style="font-size:.7rem;color:#666">Fat</div></div>
    </div>
    ${selPlan.meals.map(m=>{
      const mt=mealTotal(m.rows);
      return `<h3 style="font-family:Arial,sans-serif;font-size:.95rem;margin:16px 0 8px;color:#1a1a1a">${m.time}</h3>
      <table style="width:100%;border-collapse:collapse;margin-bottom:4px">
        <thead><tr style="background:#1a1a1a">
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:left;font-family:Arial,sans-serif">FOOD</th>
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:left;font-family:Arial,sans-serif">QUANTITY</th>
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:right;font-family:Arial,sans-serif">KCAL</th>
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:right;font-family:Arial,sans-serif">PROTEIN</th>
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:right;font-family:Arial,sans-serif">CARBS</th>
          <th style="color:#fff;font-size:.7rem;padding:6px 8px;text-align:right;font-family:Arial,sans-serif">FAT</th>
        </tr></thead>
        <tbody>
          ${m.rows.map(r=>`<tr><td style="padding:6px 8px;border-bottom:1px solid #eee;font-size:.82rem">${r.food}</td><td style="padding:6px 8px;border-bottom:1px solid #eee;font-size:.78rem;color:#555">${r.qty}</td><td style="padding:6px 8px;border-bottom:1px solid #eee;text-align:right;font-size:.82rem">${r.cal}</td><td style="padding:6px 8px;border-bottom:1px solid #eee;text-align:right;font-size:.82rem;color:#22a050">${r.p}g</td><td style="padding:6px 8px;border-bottom:1px solid #eee;text-align:right;font-size:.82rem">${r.c}g</td><td style="padding:6px 8px;border-bottom:1px solid #eee;text-align:right;font-size:.82rem">${r.f}g</td></tr>`).join('')}
          <tr style="background:#f9f6ef;font-weight:700"><td colspan="2" style="padding:6px 8px;font-size:.78rem;font-family:Arial,sans-serif">MEAL TOTAL</td><td style="padding:6px 8px;text-align:right;font-size:.82rem;color:#D4942A">${mt.cal}</td><td style="padding:6px 8px;text-align:right;font-size:.82rem;color:#22a050">${mt.p}g</td><td style="padding:6px 8px;text-align:right;font-size:.82rem">${mt.c}g</td><td style="padding:6px 8px;text-align:right;font-size:.82rem">${mt.f}g</td></tr>
        </tbody>
      </table>`;
    }).join('')}
    <h3 style="font-family:Arial,sans-serif;font-size:.95rem;margin:20px 0 8px;color:#1a1a1a">🛒 Shopping List</h3>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
      ${[...new Set(selPlan.meals.flatMap(m=>m.rows.map(r=>r.food)))].map(f=>`<div style="background:#f9f6ef;border:1px solid #ddd;border-radius:4px;padding:6px 8px;font-size:.78rem">☐ ${f}</div>`).join('')}
    </div>`;
  document.getElementById('printContent').innerHTML=html;
  document.getElementById('printModal').style.display='block';
}
function closePrint(){document.getElementById('printModal').style.display='none';}

// ══════════════════════════════════════
//   FIREBASE INTEGRATION (optional)
// ══════════════════════════════════════
async function loadDietAdmin(){
  try{
    if(typeof firebase==='undefined')return;
    const snap=await firebase.database().ref('dietAdmin').once('value');
    const v=snap.val();if(!v)return;
    if(v.tip){
      document.getElementById('tipText').textContent=v.tip;
      if(v.tipCoach) document.getElementById('tipText').textContent+=` ${v.tipCoach}`;
    }
    if(v.featured){
      // Auto-select featured plan
      selDPlan(v.featured);
    }
  }catch(e){console.warn('Diet admin load:',e);}
}

// ══════════════════════════════════════
//   INIT
// ══════════════════════════════════════
renderTip();
initGoalGrid();
loadDietAdmin();
</script>
</body>
</html>
