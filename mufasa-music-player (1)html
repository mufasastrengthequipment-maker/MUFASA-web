<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MUFASA — Sound & Strength</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --g:#D4942A;--gl:#F0B84A;--gd:#A8741F;
  --gdim:rgba(212,148,42,.18);--gfaint:rgba(212,148,42,.06);
  --bg:#050403;--s1:#0C0A08;--s2:#121008;--card:#18150F;--card2:#1F1B12;
  --b1:rgba(212,148,42,.13);--b2:rgba(212,148,42,.32);--b3:rgba(212,148,42,.55);
  --w:#F4EFE4;--grey:#A09890;--dim:#7A7570;
  --r:6px;--r2:12px;--r3:20px;--r4:50px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:'Barlow',sans-serif;
  background:var(--bg);
  color:var(--w);
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  overflow-x:hidden;
}

/* BACKGROUND AMBIENCE */
body::before{
  content:'';
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 50%, rgba(212,148,42,.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 80% 30%, rgba(168,116,31,.04) 0%, transparent 70%);
  pointer-events:none;z-index:0;
}
body::after{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg width='200' height='200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  opacity:.4;pointer-events:none;z-index:0;
}

/* MAIN WRAPPER */
.player-wrapper{
  position:relative;z-index:1;
  width:100%;max-width:780px;
  display:grid;
  grid-template-columns:300px 1fr;
  gap:0;
  background:var(--card);
  border:1px solid var(--b2);
  border-radius:18px;
  overflow:hidden;
  box-shadow:
    0 0 0 1px rgba(212,148,42,.08),
    0 24px 60px rgba(0,0,0,.75),
    0 0 80px rgba(212,148,42,.07),
    inset 0 1px 0 rgba(212,148,42,.08);
}

/* LEFT PANEL */
.panel-left{
  background:var(--s1);
  border-right:1px solid var(--b1);
  display:flex;flex-direction:column;
  padding:24px 22px;
  gap:18px;
  position:relative;
  overflow:hidden;
}
.panel-left::before{
  content:'';position:absolute;
  top:-60px;left:-60px;
  width:280px;height:280px;
  background:radial-gradient(circle,rgba(212,148,42,.08),transparent 70%);
  pointer-events:none;
}

/* BRAND HEADER */
.brand{display:flex;align-items:center;gap:10px;}
.brand-icon{
  width:36px;height:36px;
  background:linear-gradient(135deg,var(--gd),var(--gl));
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;flex-shrink:0;
}
.brand-name{
  font-family:'Anton',sans-serif;
  font-size:1.1rem;letter-spacing:.08em;
  color:var(--g);
}
.brand-sub{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.6rem;letter-spacing:.25em;
  color:var(--dim);text-transform:uppercase;
}

/* ALBUM ART */
.art-wrap{
  position:relative;
  width:100%;
  aspect-ratio:1;
  border-radius:var(--r2);
  overflow:hidden;
  background:var(--card2);
  border:1px solid var(--b1);
  flex-shrink:0;
}
.art-img{
  width:100%;height:100%;
  object-fit:cover;
  transition:transform .6s ease;
}
.art-img.spin{animation:artspin 8s linear infinite;}
@keyframes artspin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.art-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,4,3,.8) 0%,transparent 50%);
}
.art-badge{
  position:absolute;bottom:12px;left:12px;
  background:var(--gdim);border:1px solid var(--b2);
  border-radius:4px;padding:3px 8px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.6rem;font-weight:700;letter-spacing:.2em;
  color:var(--gl);text-transform:uppercase;
}
.art-vinyl{
  position:absolute;top:50%;right:-30px;
  transform:translateY(-50%);
  width:80px;height:80px;
  border-radius:50%;
  background:conic-gradient(
    #1a1206 0deg,#2a1d0a 30deg,#1a1206 60deg,
    #2a1d0a 90deg,#1a1206 120deg,#2a1d0a 150deg,
    #1a1206 180deg,#2a1d0a 210deg,#1a1206 240deg,
    #2a1d0a 270deg,#1a1206 300deg,#2a1d0a 330deg,#1a1206 360deg
  );
  border:2px solid var(--b2);
  opacity:0;transition:opacity .4s,right .4s;
  display:flex;align-items:center;justify-content:center;
}
.art-vinyl::after{content:'';width:16px;height:16px;border-radius:50%;background:var(--g);box-shadow:0 0 0 3px var(--bg);}
.art-wrap:hover .art-vinyl{opacity:.7;right:12px;}
.art-vinyl.playing{animation:vinyl 2s linear infinite;}
@keyframes vinyl{from{transform:translateY(-50%) rotate(0)}to{transform:translateY(-50%) rotate(360deg)}}

/* TRACK INFO */
.track-info{text-align:center;}
.track-title{
  font-family:'Anton',sans-serif;
  font-size:1.3rem;letter-spacing:.04em;
  color:var(--w);
  line-height:1.1;
  margin-bottom:5px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.track-artist{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.8rem;font-weight:600;letter-spacing:.14em;
  color:var(--g);text-transform:uppercase;
}
.track-album{
  font-family:'Barlow',sans-serif;
  font-size:.72rem;color:var(--dim);margin-top:2px;
}

/* PROGRESS */
.prog-wrap{display:flex;flex-direction:column;gap:6px;}
.prog-bar-outer{
  width:100%;height:4px;
  background:var(--b1);border-radius:4px;
  cursor:pointer;position:relative;overflow:hidden;
}
.prog-bar-fill{
  height:100%;
  background:linear-gradient(90deg,var(--gd),var(--gl));
  border-radius:4px;width:0%;
  transition:width .1s linear;
  position:relative;
}
.prog-bar-fill::after{
  content:'';
  position:absolute;right:-1px;top:50%;transform:translateY(-50%);
  width:8px;height:8px;
  background:var(--gl);border-radius:50%;
  box-shadow:0 0 6px var(--g);
  opacity:0;transition:opacity .2s;
}
.prog-bar-outer:hover .prog-bar-fill::after{opacity:1;}
.prog-times{
  display:flex;justify-content:space-between;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.68rem;color:var(--dim);letter-spacing:.05em;
}

/* CONTROLS */
.controls{display:flex;align-items:center;justify-content:center;gap:8px;}
.ctrl-btn{
  background:none;border:none;
  color:var(--grey);cursor:pointer;
  width:36px;height:36px;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  transition:color .2s,background .2s,transform .15s;
}
.ctrl-btn:hover{color:var(--gl);background:var(--gfaint);}
.ctrl-btn.active{color:var(--g);}
.ctrl-btn svg{width:16px;height:16px;fill:currentColor;}
.ctrl-play{
  background:linear-gradient(135deg,var(--gd),var(--gl));
  color:var(--bg);
  width:52px;height:52px;
  font-size:1.2rem;
  box-shadow:0 4px 20px rgba(212,148,42,.35);
}
.ctrl-play:hover{
  color:var(--bg);
  transform:scale(1.07);
  box-shadow:0 6px 26px rgba(212,148,42,.5);
  background:linear-gradient(135deg,var(--gd),var(--gl));
}
.ctrl-play svg{width:20px;height:20px;}

/* VOLUME */
.vol-wrap{display:flex;align-items:center;gap:8px;}
.vol-icon{color:var(--dim);font-size:.85rem;cursor:pointer;transition:color .2s;flex-shrink:0;}
.vol-icon:hover{color:var(--g);}
.vol-slider{
  flex:1;-webkit-appearance:none;appearance:none;
  height:3px;border-radius:3px;outline:none;cursor:pointer;
  background:linear-gradient(to right,var(--g) var(--vol,70%),var(--b1) var(--vol,70%));
}
.vol-slider::-webkit-slider-thumb{
  -webkit-appearance:none;
  width:12px;height:12px;border-radius:50%;
  background:var(--gl);
  box-shadow:0 0 6px rgba(212,148,42,.5);
  cursor:pointer;transition:transform .15s;
}
.vol-slider::-webkit-slider-thumb:hover{transform:scale(1.3);}

/* RIGHT PANEL */
.panel-right{
  display:flex;flex-direction:column;
  background:var(--bg);
}

/* VISUALIZER */
.viz-wrap{
  position:relative;
  height:100px;
  background:var(--s2);
  border-bottom:1px solid var(--b1);
  overflow:hidden;
}
canvas#viz{
  width:100%;height:100%;
  display:block;
}
.viz-label{
  position:absolute;top:10px;right:14px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.6rem;letter-spacing:.25em;
  color:var(--b3);text-transform:uppercase;
}
.viz-glow{
  position:absolute;bottom:0;left:0;right:0;
  height:40px;
  background:linear-gradient(to top,var(--bg),transparent);
  pointer-events:none;
}

/* PLAYLIST */
.playlist-header{
  padding:16px 20px 10px;
  display:flex;align-items:center;justify-content:space-between;
}
.pl-title{
  font-family:'Anton',sans-serif;
  font-size:.9rem;letter-spacing:.1em;color:var(--grey);
}
.pl-count{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.7rem;color:var(--dim);letter-spacing:.1em;
}

.playlist{
  flex:1;overflow-y:auto;
  padding:0 12px 12px;
  scrollbar-width:thin;
  scrollbar-color:var(--b2) transparent;
}
.playlist::-webkit-scrollbar{width:3px;}
.playlist::-webkit-scrollbar-track{background:transparent;}
.playlist::-webkit-scrollbar-thumb{background:var(--b2);border-radius:3px;}

.pl-item{
  display:flex;align-items:center;gap:12px;
  padding:9px 10px;
  border-radius:var(--r);
  cursor:pointer;
  transition:background .2s;
  border:1px solid transparent;
  margin-bottom:2px;
  position:relative;
}
.pl-item:hover{background:var(--gfaint);}
.pl-item.active{
  background:var(--gdim);
  border-color:var(--b2);
}
.pl-item.active .pl-num{display:none;}
.pl-item.active .pl-eq{display:flex;}
.pl-num{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.7rem;color:var(--dim);
  width:20px;text-align:center;flex-shrink:0;
}
.pl-eq{
  display:none;width:20px;height:14px;
  align-items:flex-end;justify-content:center;gap:2px;flex-shrink:0;
}
.pl-eq span{
  display:block;width:3px;
  background:var(--g);border-radius:2px;
  animation:eq 0.8s ease infinite alternate;
}
.pl-eq span:nth-child(1){height:60%;animation-delay:0s;}
.pl-eq span:nth-child(2){height:100%;animation-delay:.2s;}
.pl-eq span:nth-child(3){height:40%;animation-delay:.4s;}
@keyframes eq{from{transform:scaleY(0.3)}to{transform:scaleY(1)}}
.pl-eq.paused span{animation-play-state:paused;}

.pl-thumb{
  width:42px;height:42px;border-radius:6px;
  background:var(--card2);
  flex-shrink:0;overflow:hidden;
  border:1px solid var(--b1);
  display:flex;align-items:center;justify-content:center;
  color:var(--dim);font-size:.8rem;
}
.pl-thumb img{width:100%;height:100%;object-fit:cover;}
.pl-info{flex:1;min-width:0;}
.pl-song{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.85rem;font-weight:600;
  color:var(--w);letter-spacing:.02em;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.pl-item.active .pl-song{color:var(--gl);}
.pl-artist{
  font-family:'Barlow',sans-serif;
  font-size:.7rem;color:var(--dim);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.pl-dur{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.7rem;color:var(--dim);flex-shrink:0;
}

/* REMOVE BUTTON */
.pl-remove{
  display:flex;align-items:center;justify-content:center;
  width:22px;height:22px;
  border-radius:50%;
  background:none;border:none;
  color:var(--dim);
  cursor:pointer;
  flex-shrink:0;
  opacity:0;
  transition:opacity .15s,color .15s,background .15s;
  font-size:.85rem;
  line-height:1;
}
.pl-item:hover .pl-remove{opacity:1;}
.pl-remove:hover{
  color:#e05555;
  background:rgba(224,85,85,.12);
  opacity:1;
}

/* FOOTER */
.player-footer{
  padding:12px 20px;
  border-top:1px solid var(--b1);
  display:flex;align-items:center;justify-content:space-between;
  background:var(--s2);
}
.footer-live{
  display:flex;align-items:center;gap:6px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.68rem;letter-spacing:.15em;color:var(--dim);
  text-transform:uppercase;
}
.live-dot{
  width:5px;height:5px;background:var(--g);border-radius:50%;
  animation:blink 2s ease infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.footer-note{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.65rem;color:var(--dim);letter-spacing:.1em;
}

/* UPLOAD HINT */
.upload-hint{
  margin:0 20px 12px;
  padding:10px 14px;
  background:var(--gdim);
  border:1px dashed var(--b2);
  border-radius:var(--r);
  font-family:'Barlow Condensed',sans-serif;
  font-size:.72rem;color:var(--g);letter-spacing:.08em;
  text-align:center;
  cursor:pointer;transition:background .2s;
}
.upload-hint:hover{background:rgba(212,148,42,.25);}
#file-input{display:none;}

/* RESPONSIVE */
@media(max-width:640px){
  .player-wrapper{
    grid-template-columns:1fr;
    max-width:360px;
  }
  .panel-left{padding:20px 18px;}
  .art-wrap{max-width:180px;margin:0 auto;}
  .viz-wrap{height:60px;}
}

/* ANIMATIONS */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(16px);}
  to{opacity:1;transform:translateY(0);}
}
.player-wrapper{animation:fadeUp .6s ease both;}
</style>
