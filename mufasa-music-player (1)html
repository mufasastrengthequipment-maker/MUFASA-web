    title:    (s.title  || 'UNTITLED').toUpperCase(),
    artist:   (s.artist || 'MUFASA RADIO').toUpperCase(),
    album:    CAT_GENRE[s.cat] ? CAT_GENRE[s.cat] + ' • Playlist' : 'Mufasa Playlist',
    genre:    CAT_GENRE[s.cat] || 'Music',
    duration: s.dur || '0:00',
    src:      s.src || '',
    art:      s.img || null,
    fbId:     s.id
  };
}

/* STATE */
let currentIdx = 0;
let isPlaying = false;
let isShuffle = false;
let isRepeat = false;
let isMuted = false;
let audioCtx = null;
let analyser = null;
let sourceNode = null;
let animFrame = null;
let userTracks = [];
let allTracks = [];

const audio = document.getElementById('audio-el');
const canvas = document.getElementById('viz');
const ctx2d  = canvas.getContext('2d');

/* ─── BUILD PLAYLIST UI ─── */
function buildPlaylist(){
  const pl = document.getElementById('playlist');
  pl.innerHTML = '';
  allTracks.forEach((t, i) => {
    const item = document.createElement('div');
    item.className = 'pl-item' + (i === currentIdx ? ' active' : '');
    item.id = 'pl-' + i;
    item.onclick = () => loadTrack(i, true);
    item.innerHTML = `
      <div class="pl-num">${i+1}</div>
      <div class="pl-eq ${isPlaying && i===currentIdx ? '' : 'paused'}">
        <span></span><span></span><span></span>
      </div>
      <div class="pl-thumb">${t.art ? `<img src="${t.art}">` : '🎵'}</div>
      <div class="pl-info">
        <div class="pl-song">${t.title}</div>
        <div class="pl-artist">${t.artist}</div>
      </div>
      <div class="pl-dur">${t.duration}</div>
      <button class="pl-remove" title="Remove from playlist" onclick="removeTrack(event, ${i})">✕</button>
    `;
    pl.appendChild(item);
  });
  document.getElementById('pl-count').textContent = allTracks.length + ' Tracks';
}

/* ─── REMOVE TRACK ─── */
function removeTrack(e, idx){
  e.stopPropagation();
  if(allTracks.length <= 1){
    const item = document.getElementById('pl-' + idx);
    if(item){ item.style.borderColor='rgba(224,85,85,.4)'; setTimeout(()=>item.style.borderColor='',600); }
    return;
  }
  const wasPlaying = isPlaying;
  const removingCurrent = (idx === currentIdx);
  clearInterval(simTimer); simPos = 0;

  allTracks.splice(idx, 1);

  if(removingCurrent){
    // Play what is now at the same index (or last if we removed the last)
    const newIdx = Math.min(idx, allTracks.length - 1);
    currentIdx = newIdx;
    buildPlaylist();
    loadTrack(newIdx, wasPlaying);
  } else {
    // Adjust currentIdx if a track before it was removed
    if(idx < currentIdx) currentIdx--;
    buildPlaylist();
    // Re-highlight correct active item
    document.querySelectorAll('.pl-item').forEach((el, i) => {
      el.classList.toggle('active', i === currentIdx);
    });
    document.getElementById('pl-count').textContent = allTracks.length + ' Tracks';
  }
}

/* ─── LOAD TRACK ─── */
function loadTrack(idx, autoplay = false){
  currentIdx = idx;
  const t = allTracks[idx];

  document.getElementById('track-title').textContent  = t.title;
  document.getElementById('track-artist').textContent = t.artist;
  document.getElementById('track-album').textContent  = t.album;
  document.getElementById('art-genre').textContent    = t.genre || 'Workout Mix';

  if(t.art) {
    document.getElementById('art-img').src = t.art;
    document.getElementById('art-img').style.display = 'block';
  }

  if(t.src){
    audio.src = t.src;
    if(autoplay){ audio.play().then(() => setPlayState(true)).catch(()=>{}); }
  } else {
    audio.src = '';
    if(autoplay) simulatePlay();
  }

  document.querySelectorAll('.pl-item').forEach((el, i) => {
    el.classList.toggle('active', i === idx);
  });
  document.getElementById('prog-fill').style.width = '0%';
  document.getElementById('time-cur').textContent = '0:00';
  document.getElementById('time-dur').textContent = t.duration || '0:00';

  const item = document.getElementById('pl-' + idx);
  if(item) item.scrollIntoView({behavior:'smooth',block:'nearest'});
}

/* ─── PLAY STATE ─── */
function setPlayState(playing){
  isPlaying = playing;
  document.getElementById('ico-play').style.display  = playing ? 'none'  : '';
  document.getElementById('ico-pause').style.display = playing ? '' : 'none';
  document.getElementById('art-img').classList.toggle('spin', playing);
  document.getElementById('art-vinyl').classList.toggle('playing', playing);
  document.querySelectorAll('.pl-eq').forEach((el, i) => {
    el.classList.toggle('paused', !playing || i !== currentIdx);
  });
  if(playing) startViz();
  else        stopViz();
}

function togglePlay(){
  if(audio.src && audio.src !== window.location.href){
    if(isPlaying){ audio.pause(); setPlayState(false); }
    else { audio.play().then(() => setPlayState(true)).catch(()=>{}); }
  } else {
    if(isPlaying){ setPlayState(false); }
    else { simulatePlay(); }
  }
}

/* Simulate playback when no real audio loaded */
let simTimer = null;
let simPos = 0;
let simMax = 225; // seconds
function simulatePlay(){
  setPlayState(true);
  clearInterval(simTimer);
  const t = allTracks[currentIdx];
  const [m,s] = (t.duration || '3:00').split(':').map(Number);
  simMax = m*60 + s;
  simTimer = setInterval(() => {
    simPos++;
    if(simPos >= simMax){ simPos = 0; clearInterval(simTimer); nextTrack(); return; }
    const pct = (simPos / simMax * 100).toFixed(1);
    document.getElementById('prog-fill').style.width = pct + '%';
    document.getElementById('time-cur').textContent = fmt(simPos);
  }, 1000);
}
function fmt(s){ return Math.floor(s/60) + ':' + String(s%60).padStart(2,'0'); }

function prevTrack(){
  clearInterval(simTimer); simPos = 0;
  let idx = isShuffle ? randIdx() : (currentIdx - 1 + allTracks.length) % allTracks.length;
  loadTrack(idx, isPlaying);
}
function nextTrack(){
  clearInterval(simTimer); simPos = 0;
  let idx = isRepeat ? currentIdx : isShuffle ? randIdx() : (currentIdx + 1) % allTracks.length;
  loadTrack(idx, true);
}
function randIdx(){ let r; do{ r = Math.floor(Math.random()*allTracks.length); } while(r===currentIdx && allTracks.length>1); return r; }

function toggleShuffle(){
  isShuffle = !isShuffle;
  document.getElementById('btn-shuffle').classList.toggle('active', isShuffle);
}
function toggleRepeat(){
  isRepeat = !isRepeat;
  document.getElementById('btn-repeat').classList.toggle('active', isRepeat);
}

/* ─── VOLUME ─── */
function setVolume(v){
  audio.volume = v / 100;
  const pct = v + '%';
  document.getElementById('vol-slider').style.setProperty('--vol', pct);
  document.getElementById('vol-slider').title = 'Volume: ' + v + '%';
}
function toggleMute(){
  isMuted = !isMuted;
  audio.muted = isMuted;
  document.querySelector('.vol-icon').textContent = isMuted ? '🔇' : '🔊';
}

/* ─── PROGRESS SEEK ─── */
document.getElementById('prog-bar').addEventListener('click', function(e){
  if(audio.duration){
    const pct = e.offsetX / this.offsetWidth;
    audio.currentTime = audio.duration * pct;
  } else if(simMax > 0){
    const pct = e.offsetX / this.offsetWidth;
    simPos = Math.floor(simMax * pct);
  }
});
audio.addEventListener('timeupdate', () => {
  if(!audio.duration) return;
  const pct = (audio.currentTime / audio.duration * 100).toFixed(1);
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('time-cur').textContent = fmt(Math.floor(audio.currentTime));
  document.getElementById('time-dur').textContent = fmt(Math.floor(audio.duration));
});
audio.addEventListener('ended', () => { if(!isRepeat) nextTrack(); else audio.play(); });

/* ─── FILE UPLOAD ─── */
function loadFiles(event){
  const files = Array.from(event.target.files);
  files.forEach(file => {
    const url = URL.createObjectURL(file);
    const name = file.name.replace(/\.[^/.]+$/, '').toUpperCase();
    allTracks.push({
      title: name,
      artist: 'YOUR TRACK',
      album: 'Uploaded',
      genre: 'My Music',
      duration: '–:––',
      src: url
    });
  });
  buildPlaylist();
  if(files.length > 0) loadTrack(allTracks.length - files.length, true);
}

/* ─── VISUALIZER ─── */
function initAudioContext(){
  if(audioCtx) return;
  try{
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 128;
    sourceNode = audioCtx.createMediaElementSource(audio);
    sourceNode.connect(analyser);
    analyser.connect(audioCtx.destination);
  } catch(e){ console.log('AudioContext not available'); }
}

function startViz(){
  initAudioContext();
  resizeCanvas();
  if(analyser){
    drawAnalyser();
  } else {
    drawFake();
  }
}
function stopViz(){
  cancelAnimationFrame(animFrame);
  ctx2d.clearRect(0, 0, canvas.width, canvas.height);
  drawIdle();
}

function resizeCanvas(){
  canvas.width  = canvas.offsetWidth  * window.devicePixelRatio;
  canvas.height = canvas.offsetHeight * window.devicePixelRatio;
  ctx2d.scale(window.devicePixelRatio, window.devicePixelRatio);
}

function drawAnalyser(){
  animFrame = requestAnimationFrame(drawAnalyser);
  const data = new Uint8Array(analyser.frequencyBinCount);
  analyser.getByteFrequencyData(data);
  drawBars(data);
}

let fakePhase = 0;
function drawFake(){
  animFrame = requestAnimationFrame(drawFake);
  fakePhase += 0.05;
  const bars = 32;
  const data = new Uint8Array(bars);
  for(let i = 0; i < bars; i++){
    data[i] = 80 + Math.sin(fakePhase + i * 0.4) * 60 + Math.random() * 30;
  }
  drawBars(data);
}

function drawBars(data){
  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  ctx2d.clearRect(0,0,W,H);
  const n = data.length;
  const bw = (W / n) - 1.5;
  const grad = ctx2d.createLinearGradient(0, H, 0, 0);
  grad.addColorStop(0, 'rgba(168,116,31,0.9)');
  grad.addColorStop(0.5, 'rgba(212,148,42,0.85)');
  grad.addColorStop(1, 'rgba(240,184,74,0.4)');
  for(let i = 0; i < n; i++){
    const v = data[i] / 255;
    const h = Math.max(2, v * H * 0.9);
    const x = i * (bw + 1.5);
    ctx2d.fillStyle = grad;
    ctx2d.beginPath();
    ctx2d.roundRect(x, H - h, bw, h, 2);
    ctx2d.fill();
    // Mirror reflection
    ctx2d.globalAlpha = 0.15;
    ctx2d.beginPath();
    ctx2d.roundRect(x, H, bw, h * 0.4, 2);
    ctx2d.fill();
    ctx2d.globalAlpha = 1;
  }
}

function drawIdle(){
  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  ctx2d.clearRect(0,0,W,H);
  const n = 32;
  const bw = (W / n) - 1.5;
  for(let i = 0; i < n; i++){
    const h = 3;
    const x = i * (bw + 1.5);
    ctx2d.fillStyle = 'rgba(212,148,42,0.2)';
    ctx2d.beginPath();
    ctx2d.roundRect(x, H/2 - h/2, bw, h, 1);
    ctx2d.fill();
  }
}

/* ─── INIT ─── */
window.addEventListener('resize', () => {
  resizeCanvas();
  if(!isPlaying) drawIdle();
});

setVolume(70);
drawIdle();

/* ─── FIREBASE INIT & TRACK LOADING ─── */
let fbDb = null;

function initWithTracks(tracks){
  allTracks = tracks.length ? tracks : FALLBACK_TRACKS.map(t => ({...t}));
  buildPlaylist();
  loadTrack(0);
}

function loadFromFirebase(){
  try {
    // Re-use existing Firebase app if already initialized (e.g. in parent page)
    try { fbDb = firebase.app().database(); }
    catch(e) { firebase.initializeApp(FIREBASE_CONFIG); fbDb = firebase.database(); }

    // Show loading state
    document.getElementById('pl-count').textContent = 'Loading…';

    fbDb.ref('songs').orderByChild('_ts').once('value').then(snap => {
      const songs = [];
      snap.forEach(child => songs.push({ id: child.key, ...child.val() }));

      // Admin uses reverse order (most-recent first when sorted by _ts desc)
      // Mirror same ordering: reverse the _ts-ascending list
      songs.reverse();

      if(songs.length){
        initWithTracks(songs.map(fbSongToTrack));
      } else {
        initWithTracks([]);
      }

      // Live listener — update playlist if admin adds/removes/reorders
      fbDb.ref('songs').on('value', snap2 => {
        const updated = [];
        snap2.forEach(child => updated.push({ id: child.key, ...child.val() }));
        updated.reverse();
        if(!updated.length) return;
        const newTracks = updated.map(fbSongToTrack);
        const wasIdx = currentIdx;
        const wasId = allTracks[currentIdx]?.fbId;
        allTracks = newTracks;
        // Try to keep the same track playing after live update
        const sameIdx = newTracks.findIndex(t => t.fbId === wasId);
        currentIdx = sameIdx >= 0 ? sameIdx : Math.min(wasIdx, newTracks.length - 1);
        buildPlaylist();
        document.querySelectorAll('.pl-item').forEach((el, i) => el.classList.toggle('active', i === currentIdx));
      });

    }).catch(() => {
      initWithTracks([]);
    });
  } catch(e) {
    console.warn('Firebase unavailable, using fallback tracks:', e);
    initWithTracks([]);
  }
}

loadFromFirebase();

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if(['INPUT','TEXTAREA'].includes(e.target.tagName)) return;
  if(e.key === ' '){ e.preventDefault(); togglePlay(); }
  else if(e.key === 'ArrowRight'){ nextTrack(); }
  else if(e.key === 'ArrowLeft'){ prevTrack(); }
  else if(e.key === 'ArrowUp'){ const v=Math.min(100,parseInt(document.getElementById('vol-slider').value)+5); document.getElementById('vol-slider').value=v; setVolume(v); }
  else if(e.key === 'ArrowDown'){ const v=Math.max(0,parseInt(document.getElementById('vol-slider').value)-5); document.getElementById('vol-slider').value=v; setVolume(v); }
});
</script>
