<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MUFASA PLAYER</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap');

  *{box-sizing:border-box;margin:0;padding:0}
  body{
    background:#080c18;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Nunito',sans-serif;
    padding:16px;
  }

  .app{
    width:100%;
    max-width:420px;
    background:linear-gradient(160deg,#0f0a25 0%,#0a1628 50%,#080f1e 100%);
    border-radius:20px;
    overflow:hidden;
    border:1px solid rgba(245,166,35,0.15);
    box-shadow:0 30px 80px rgba(0,0,0,0.7),0 0 0 0.5px rgba(245,166,35,0.1);
    position:relative;
  }

  /* Ambient glow */
  .app::before{
    content:'';
    position:absolute;
    top:-60px;right:-60px;
    width:200px;height:200px;
    background:radial-gradient(circle,rgba(245,166,35,0.08) 0%,transparent 70%);
    pointer-events:none;
    z-index:0;
  }

  /* HEADER */
  .header{
    position:relative;z-index:1;
    padding:16px 18px 14px;
    background:rgba(0,0,0,0.3);
    border-bottom:0.5px solid rgba(245,166,35,0.15);
    display:flex;align-items:center;gap:12px;
  }
  .logo{
    width:46px;height:46px;border-radius:50%;
    background:linear-gradient(135deg,#f5a623,#e85d04);
    display:flex;align-items:center;justify-content:center;
    font-family:'Bebas Neue',cursive;font-size:22px;color:#fff;
    flex-shrink:0;
    box-shadow:0 4px 16px rgba(245,166,35,0.4);
  }
  .brand{flex:1}
  .brand-name{font-family:'Bebas Neue',cursive;font-size:22px;letter-spacing:3px;color:#f5a623;line-height:1}
  .brand-sub{font-size:9px;letter-spacing:4px;color:rgba(245,166,35,0.45);margin-top:1px}
  .count-badge{
    background:rgba(245,166,35,0.12);
    color:#f5a623;border:0.5px solid rgba(245,166,35,0.3);
    font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;
  }

  /* LOAD ZONE */
  #load-screen{position:relative;z-index:1;padding:20px 18px 24px}
  .drop-zone{
    border:1.5px dashed rgba(245,166,35,0.3);
    border-radius:14px;
    padding:36px 20px;
    text-align:center;
    cursor:pointer;
    transition:all 0.25s;
    background:rgba(245,166,35,0.02);
  }
  .drop-zone:hover,.drop-zone.drag{
    border-color:#f5a623;
    background:rgba(245,166,35,0.06);
  }
  .drop-zone .dz-icon{font-size:52px;color:rgba(245,166,35,0.4);display:block;margin-bottom:14px}
  .drop-zone h2{font-size:18px;font-weight:800;color:#fff;margin-bottom:8px}
  .drop-zone p{font-size:13px;color:rgba(255,255,255,0.35);line-height:1.7}
  .dz-hint{
    margin-top:16px;display:inline-flex;align-items:center;gap:6px;
    background:rgba(245,166,35,0.08);border:0.5px solid rgba(245,166,35,0.2);
    border-radius:20px;padding:6px 14px;font-size:11px;color:rgba(245,166,35,0.7);
  }
  .formats{
    display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-top:14px;
  }
  .fmt-tag{
    background:rgba(255,255,255,0.04);border:0.5px solid rgba(255,255,255,0.1);
    border-radius:4px;padding:3px 8px;font-size:10px;color:rgba(255,255,255,0.3);
  }

  /* PLAYER SECTION */
  #player-section{display:none;position:relative;z-index:1;flex-direction:column}

  /* Search + toolbar */
  .toolbar{
    display:flex;gap:8px;padding:10px 14px;
    background:rgba(0,0,0,0.25);border-bottom:0.5px solid rgba(255,255,255,0.06);
  }
  .toolbar input{
    flex:1;background:rgba(255,255,255,0.06);
    border:0.5px solid rgba(255,255,255,0.1);border-radius:8px;
    padding:8px 12px;color:#fff;font-size:13px;font-family:'Nunito',sans-serif;outline:none;
    transition:border-color 0.2s;
  }
  .toolbar input:focus{border-color:rgba(245,166,35,0.4)}
  .toolbar input::placeholder{color:rgba(255,255,255,0.2)}
  .add-more-btn{
    background:transparent;border:0.5px solid rgba(245,166,35,0.4);
    color:#f5a623;border-radius:8px;padding:8px 12px;cursor:pointer;
    font-size:12px;font-weight:700;display:flex;align-items:center;gap:4px;
    transition:all 0.15s;white-space:nowrap;font-family:'Nunito',sans-serif;
  }
  .add-more-btn:hover{background:rgba(245,166,35,0.1)}

  /* Track list */
  .track-list{
    max-height:260px;overflow-y:auto;
    scrollbar-width:thin;scrollbar-color:rgba(245,166,35,0.2) transparent;
  }
  .track-list::-webkit-scrollbar{width:3px}
  .track-list::-webkit-scrollbar-thumb{background:rgba(245,166,35,0.2);border-radius:2px}
  .track{
    display:flex;align-items:center;gap:10px;
    padding:9px 14px;cursor:pointer;
    border-bottom:0.5px solid rgba(255,255,255,0.04);
    transition:background 0.12s;
    position:relative;
  }
  .track::after{
    content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
    background:linear-gradient(180deg,#f5a623,#e85d04);
    transform:scaleY(0);transition:transform 0.15s;border-radius:0 2px 2px 0;
  }
  .track:hover{background:rgba(255,255,255,0.04)}
  .track.active{background:rgba(245,166,35,0.08)}
  .track.active::after{transform:scaleY(1)}
  .t-num{width:22px;font-size:11px;color:rgba(255,255,255,0.2);text-align:center;flex-shrink:0}
  .t-icon{
    width:36px;height:36px;border-radius:7px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    background:rgba(255,255,255,0.05);font-size:15px;
  }
  .t-icon.active{background:linear-gradient(135deg,#f5a623,#e85d04)}
  .t-info{flex:1;min-width:0}
  .t-name{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff}
  .t-sub{font-size:10px;color:rgba(255,255,255,0.3);margin-top:1px}
  .t-dur{font-size:11px;color:rgba(255,255,255,0.25);flex-shrink:0;min-width:38px;text-align:right}
  .t-del{
    background:transparent;border:none;color:rgba(255,255,255,0.15);
    cursor:pointer;padding:4px;border-radius:5px;font-size:14px;flex-shrink:0;
    transition:color 0.15s;
  }
  .t-del:hover{color:#e85d04}

  /* Empty / loading state */
  .list-empty{padding:30px;text-align:center;color:rgba(255,255,255,0.2);font-size:13px}
  .list-empty i{font-size:32px;display:block;margin-bottom:8px}

  /* NOW PLAYING */
  .np-section{
    background:linear-gradient(180deg,rgba(0,0,0,0.4) 0%,rgba(10,8,30,0.95) 100%);
    border-top:0.5px solid rgba(245,166,35,0.15);
    padding:16px 18px 18px;
  }
  .np-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
  .np-art{
    width:52px;height:52px;border-radius:10px;flex-shrink:0;
    background:linear-gradient(135deg,#2a1060,#0d3a6e);
    display:flex;align-items:center;justify-content:center;font-size:26px;
    box-shadow:0 4px 16px rgba(0,0,0,0.5);
    position:relative;overflow:hidden;
  }
  .np-art::after{
    content:'';position:absolute;inset:0;
    background:linear-gradient(135deg,rgba(245,166,35,0.1),transparent);
  }
  .np-meta{flex:1;min-width:0}
  .np-name{font-size:15px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff;line-height:1.2}
  .np-artist{font-size:12px;color:rgba(255,255,255,0.4);margin-top:3px}
  .np-fav{background:transparent;border:none;font-size:22px;cursor:pointer;padding:4px;color:rgba(255,255,255,0.2);transition:all 0.15s;flex-shrink:0}
  .np-fav.on{color:#f5a623}
  .np-fav:hover{transform:scale(1.15)}

  /* Progress */
  .prog-wrap{margin-bottom:10px}
  .prog-bar{
    width:100%;height:5px;
    background:rgba(255,255,255,0.08);border-radius:3px;
    cursor:pointer;position:relative;
  }
  .prog-fill{
    height:100%;border-radius:3px;
    background:linear-gradient(90deg,#f5a623,#e85d04);
    width:0%;transition:width 0.25s linear;pointer-events:none;
  }
  .prog-thumb{
    position:absolute;top:50%;right:0;
    width:12px;height:12px;border-radius:50%;
    background:#f5a623;transform:translate(50%,-50%) scale(0);
    transition:transform 0.15s;pointer-events:none;
    box-shadow:0 0 6px rgba(245,166,35,0.6);
  }
  .prog-bar:hover .prog-thumb{transform:translate(50%,-50%) scale(1)}
  .prog-times{display:flex;justify-content:space-between;font-size:10px;color:rgba(255,255,255,0.25);margin-top:5px}

  /* Controls */
  .controls{display:flex;align-items:center;justify-content:center;gap:18px;margin:8px 0}
  .ctrl-btn{background:transparent;border:none;color:rgba(255,255,255,0.4);font-size:22px;cursor:pointer;padding:5px;transition:all 0.15s;line-height:1}
  .ctrl-btn:hover{color:#f5a623;transform:scale(1.1)}
  .ctrl-btn.on{color:#f5a623}
  .play-btn{
    width:56px;height:56px;border-radius:50%;
    background:linear-gradient(135deg,#f5a623,#e85d04);
    border:none;color:#fff;font-size:24px;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:transform 0.1s,box-shadow 0.2s;
    box-shadow:0 6px 24px rgba(245,166,35,0.4);
  }
  .play-btn:hover{box-shadow:0 8px 30px rgba(245,166,35,0.6)}
  .play-btn:active{transform:scale(0.93)}

  /* Volume */
  .vol-row{display:flex;align-items:center;gap:8px;margin-top:8px}
  .vol-row i{font-size:16px;color:rgba(255,255,255,0.25);flex-shrink:0}
  .vol-row input[type=range]{
    flex:1;-webkit-appearance:none;appearance:none;
    height:4px;background:rgba(255,255,255,0.1);border-radius:2px;outline:none;
  }
  .vol-row input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none;width:14px;height:14px;border-radius:50%;
    background:#f5a623;cursor:pointer;
  }
  .vol-row input[type=range]::-moz-range-thumb{
    width:14px;height:14px;border-radius:50%;
    background:#f5a623;cursor:pointer;border:none;
  }

  /* Tabs */
  .tabs{display:flex;padding:0 14px 0;background:rgba(0,0,0,0.2);border-bottom:0.5px solid rgba(255,255,255,0.06)}
  .tab-btn{
    flex:1;padding:9px 6px;background:transparent;border:none;
    color:rgba(255,255,255,0.35);font-size:12px;font-weight:700;cursor:pointer;
    font-family:'Nunito',sans-serif;letter-spacing:0.5px;
    border-bottom:2px solid transparent;transition:all 0.15s;
  }
  .tab-btn.active{color:#f5a623;border-bottom-color:#f5a623}
</style>
</head>
<body>
<div class="app" id="app">
  <div class="header">
    <div class="logo">M</div>
    <div class="brand">
      <div class="brand-name">MUFASA PLAYER</div>
      <div class="brand-sub">REAL AUDIO ENGINE</div>
    </div>
    <div class="count-badge" id="count-badge">0 songs</div>
  </div>

  <!-- Load Screen -->
  <div id="load-screen">
    <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
      <i class="ti ti-folder-open dz-icon"></i>
      <h2>Load Your Music</h2>
      <p>Tap to select your MP3, WAV, OGG or M4A files<br>from your device storage.<br>You can select multiple files at once.</p>
      <div class="dz-hint"><i class="ti ti-info-circle" style="font-size:12px"></i> Hold to select all files in a folder</div>
      <div class="formats">
        <span class="fmt-tag">MP3</span>
        <span class="fmt-tag">WAV</span>
        <span class="fmt-tag">OGG</span>
        <span class="fmt-tag">M4A</span>
        <span class="fmt-tag">FLAC</span>
        <span class="fmt-tag">AAC</span>
      </div>
    </div>
  </div>

  <!-- Player -->
  <div id="player-section" style="display:none;flex-direction:column">
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('all',this)">All Songs</button>
      <button class="tab-btn" onclick="switchTab('fav',this)">Favourites</button>
      <button class="tab-btn" onclick="switchTab('recent',this)">Recent</button>
    </div>
    <div class="toolbar">
      <input type="text" id="search-input" placeholder="Search songs..." oninput="renderList()">
      <button class="add-more-btn" onclick="document.getElementById('file-input').click()">
        <i class="ti ti-plus"></i> Add More
      </button>
    </div>
    <div class="track-list" id="track-list"></div>
    <div class="np-section">
      <div class="np-header">
        <div class="np-art" id="np-art">🦁</div>
        <div class="np-meta">
          <div class="np-name" id="np-name">No track selected</div>
          <div class="np-artist" id="np-artist-el">Tap a song to start</div>
        </div>
        <button class="np-fav" id="fav-btn" onclick="toggleFav()"><i class="ti ti-heart" id="heart-icon"></i></button>
      </div>
      <div class="prog-wrap">
        <div class="prog-bar" id="prog-bar" onclick="seekTo(event)">
          <div class="prog-fill" id="prog-fill"></div>
          <div class="prog-thumb" id="prog-thumb"></div>
        </div>
        <div class="prog-times">
          <span id="t-cur">0:00</span>
          <span id="t-tot">0:00</span>
        </div>
      </div>
      <div class="controls">
        <button class="ctrl-btn" id="shuf-btn" onclick="toggleShuffle()" title="Shuffle"><i class="ti ti-arrows-shuffle"></i></button>
        <button class="ctrl-btn" onclick="prevTrack()" title="Previous"><i class="ti ti-player-skip-back"></i></button>
        <button class="play-btn" id="play-btn" onclick="togglePlay()"><i class="ti ti-player-play" id="play-icon"></i></button>
        <button class="ctrl-btn" onclick="nextTrack()" title="Next"><i class="ti ti-player-skip-forward"></i></button>
        <button class="ctrl-btn" id="rep-btn" onclick="toggleRepeat()" title="Repeat"><i class="ti ti-repeat"></i></button>
      </div>
      <div class="vol-row">
        <i class="ti ti-volume"></i>
        <input type="range" min="0" max="1" step="0.01" value="0.8" id="vol-slider" oninput="setVol(this.value)">
        <i class="ti ti-volume-3"></i>
      </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" accept="audio/*" multiple style="display:none" onchange="loadFiles(event)">

<script>
let tracks = [];
let cur = -1;
let isPlaying = false;
let shuffle = false;
let repeat = false;
let curTab = 'all';
const audio = new Audio();
audio.volume = 0.8;
const durCache = {};

function fmt(s) {
  if (!isFinite(s) || isNaN(s)) return '--:--';
  s = Math.floor(s);
  const m = Math.floor(s / 60), sec = s % 60;
  return m + ':' + (sec < 10 ? '0' : '') + sec;
}

function cleanName(n) {
  return n.replace(/\.[^.]+$/, '').replace(/[_\-]+/g, ' ').trim();
}

function loadFiles(e) {
  const files = [...e.target.files];
  if (!files.length) return;
  files.forEach(f => {
    const url = URL.createObjectURL(f);
    tracks.push({ name: cleanName(f.name), artist: '', url, fav: false, added: Date.now() });
  });
  document.getElementById('load-screen').style.display = 'none';
  const ps = document.getElementById('player-section');
  ps.style.display = 'flex';
  ps.style.flexDirection = 'column';
  updateBadge();
  renderList();
  if (cur < 0) playTrack(0);
  e.target.value = '';
}

function updateBadge() {
  document.getElementById('count-badge').textContent = tracks.length + ' song' + (tracks.length !== 1 ? 's' : '');
}

function switchTab(t, btn) {
  curTab = t;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}

function getVisible() {
  const q = document.getElementById('search-input').value.toLowerCase();
  let list = tracks.map((_, i) => i);
  if (curTab === 'fav') list = list.filter(i => tracks[i].fav);
  if (curTab === 'recent') list = list.slice().sort((a, b) => tracks[b].added - tracks[a].added).slice(0, 20);
  if (q) list = list.filter(i => tracks[i].name.toLowerCase().includes(q));
  return list;
}

function renderList() {
  const el = document.getElementById('track-list');
  const idxs = getVisible();
  if (!idxs.length) {
    el.innerHTML = '<div class="list-empty"><i class="ti ti-music-off"></i>No tracks found</div>';
    return;
  }
  el.innerHTML = idxs.map((ri, vi) => {
    const t = tracks[ri];
    const act = ri === cur;
    return `<div class="track${act ? ' active' : ''}" onclick="playTrack(${ri})">
      <div class="t-num">${act && isPlaying ? '<i class="ti ti-volume" style="color:#f5a623;font-size:13px"></i>' : vi + 1}</div>
      <div class="t-icon${act ? ' active' : ''}">
        <i class="ti ti-music" style="color:${act ? '#fff' : 'rgba(255,255,255,0.2)'}"></i>
      </div>
      <div class="t-info">
        <div class="t-name">${t.name}</div>
        <div class="t-sub">${t.fav ? '<i class="ti ti-heart-filled" style="color:#f5a623;font-size:10px"></i> ' : ''}Audio file</div>
      </div>
      <div class="t-dur" id="dur-${ri}">${durCache[ri] || '--:--'}</div>
      <button class="t-del" onclick="event.stopPropagation();deleteTrack(${ri})" title="Remove">
        <i class="ti ti-trash"></i>
      </button>
    </div>`;
  }).join('');
  fetchDurations(idxs);
}

function fetchDurations(idxs) {
  idxs.forEach(i => {
    if (durCache[i]) return;
    const a = new Audio();
    a.preload = 'metadata';
    a.src = tracks[i].url;
    a.onloadedmetadata = () => {
      durCache[i] = fmt(a.duration);
      const el = document.getElementById('dur-' + i);
      if (el) el.textContent = durCache[i];
    };
  });
}

function playTrack(i) {
  if (i < 0 || i >= tracks.length) return;
  cur = i;
  const t = tracks[i];
  audio.src = t.url;
  audio.play().catch(() => {});
  document.getElementById('np-name').textContent = t.name;
  document.getElementById('np-artist-el').textContent = t.artist || 'Your Library';
  document.getElementById('heart-icon').className = t.fav ? 'ti ti-heart-filled' : 'ti ti-heart';
  document.getElementById('fav-btn').classList.toggle('on', t.fav);
  renderList();
}

audio.ontimeupdate = () => {
  if (!audio.duration) return;
  const pct = (audio.currentTime / audio.duration) * 100;
  document.getElementById('prog-fill').style.width = Math.min(pct, 100).toFixed(2) + '%';
  document.getElementById('prog-thumb').style.left = Math.min(pct, 100).toFixed(2) + '%';
  document.getElementById('t-cur').textContent = fmt(audio.currentTime);
  document.getElementById('t-tot').textContent = fmt(audio.duration);
};

audio.onplay = () => { isPlaying = true; updatePlayBtn(); renderList(); };
audio.onpause = () => { isPlaying = false; updatePlayBtn(); renderList(); };
audio.onended = () => {
  if (repeat) { audio.currentTime = 0; audio.play(); return; }
  if (shuffle) { playTrack(Math.floor(Math.random() * tracks.length)); }
  else if (cur < tracks.length - 1) { playTrack(cur + 1); }
  else { isPlaying = false; updatePlayBtn(); }
};

function updatePlayBtn() {
  document.getElementById('play-icon').className = isPlaying ? 'ti ti-player-pause' : 'ti ti-player-play';
}

function togglePlay() {
  if (cur < 0 && tracks.length > 0) { playTrack(0); return; }
  if (cur < 0) return;
  audio.paused ? audio.play() : audio.pause();
}

function prevTrack() {
  if (audio.currentTime > 3) { audio.currentTime = 0; return; }
  playTrack(cur <= 0 ? tracks.length - 1 : cur - 1);
}

function nextTrack() {
  if (shuffle) playTrack(Math.floor(Math.random() * tracks.length));
  else playTrack((cur + 1) % tracks.length);
}

function toggleShuffle() {
  shuffle = !shuffle;
  document.getElementById('shuf-btn').classList.toggle('on', shuffle);
}

function toggleRepeat() {
  repeat = !repeat;
  document.getElementById('rep-btn').classList.toggle('on', repeat);
}

function toggleFav() {
  if (cur < 0) return;
  tracks[cur].fav = !tracks[cur].fav;
  document.getElementById('heart-icon').className = tracks[cur].fav ? 'ti ti-heart-filled' : 'ti ti-heart';
  document.getElementById('fav-btn').classList.toggle('on', tracks[cur].fav);
  renderList();
}

function setVol(v) { audio.volume = parseFloat(v); }

function seekTo(e) {
  if (!audio.duration) return;
  const r = e.currentTarget.getBoundingClientRect();
  audio.currentTime = ((e.clientX - r.left) / r.width) * audio.duration;
}

function deleteTrack(i) {
  URL.revokeObjectURL(tracks[i].url);
  tracks.splice(i, 1);
  if (i === cur) {
    audio.pause(); audio.src = '';
    cur = -1; isPlaying = false; updatePlayBtn();
    document.getElementById('np-name').textContent = 'No track selected';
    document.getElementById('np-artist-el').textContent = 'Tap a song to start';
    document.getElementById('prog-fill').style.width = '0%';
    document.getElementById('t-cur').textContent = '0:00';
    document.getElementById('t-tot').textContent = '0:00';
  } else if (i < cur) cur--;
  updateBadge();
  if (!tracks.length) {
    document.getElementById('player-section').style.display = 'none';
    document.getElementById('load-screen').style.display = 'block';
  }
  renderList();
}

// Drag and drop
const dz = document.getElementById('drop-zone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('drag');
  const files = [...e.dataTransfer.files].filter(f => f.type.startsWith('audio/'));
  if (!files.length) return;
  files.forEach(f => {
    tracks.push({ name: cleanName(f.name), artist: '', url: URL.createObjectURL(f), fav: false, added: Date.now() });
  });
  document.getElementById('load-screen').style.display = 'none';
  const ps = document.getElementById('player-section');
  ps.style.display = 'flex'; ps.style.flexDirection = 'column';
  updateBadge(); renderList();
  if (cur < 0) playTrack(0);
});
</script>
</body>
</html>
